{
  "name": "@isis/ui",
  "version": "0.0.0",
  "main": "index.js",
  "type": "module",
  "exports": {
    "./styles/*.scss": {
      "default": "./styles/*.scss"
    },
    "./display/*": {
      "types": "./src/display/*.tsx",
      "default": "./src/display/*.tsx"
    },
    "./feedback/*": {
      "types": "./src/feedback/*.tsx",
      "default": "./src/feedback/*.tsx"
    },
    "./form/*": {
      "types": "./src/form/*.tsx",
      "default": "./src/form/*.tsx"
    },
    "./layout/*": {
      "types": "./src/layout/*.tsx",
      "default": "./src/layout/*.tsx"
    },
    "./overlay/*": {
      "types": "./src/overlay/*.tsx",
      "default": "./src/overlay/*.tsx"
    },
    "./utils/*": {
      "types": "./src/utils/*.ts",
      "default": "./src/utils/*.ts"
    }
  },
  "scripts": {
    "start": "http-server ui/storybook-static -p 6663",
    "dev": "storybook dev -p 6663 --ci",
    "build": "npm run build:ts && npm run build:sb",
    "build:ts": "tsc -b",
    "build:sb": "storybook build",
    "clean": "tsc -b --clean"
  },
  "dependencies": {
    "@daypicker/react": "^10.0.1",
    "@isis/common": "*",
    "@orpc/client": "^1.14.6",
    "http-server": "^14.1.1",
    "radix-ui": "^1.5.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-icons": "^5.6.0",
    "react-router": "^7.17.0",
    "suspend-react": "^0.1.3",
    "usehooks-ts": "^3.1.1"
  },
  "devDependencies": {
    "@storybook/addon-docs": "^10.4.4",
    "@storybook/builder-vite": "^10.4.4",
    "@storybook/react": "^10.4.4",
    "@storybook/react-vite": "^10.4.4",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "sass": "^1.101.0",
    "sass-embedded": "^1.100.0",
    "vite": "^8.0.16"
  },
  "optionalDependencies": {
    "zod": "^4.4.3"
  }
}
